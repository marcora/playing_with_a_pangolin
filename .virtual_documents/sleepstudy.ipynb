


import arviz as az
import bambi as bmb
import numpy as np
import pandas as pd
import pangolin as pg
import pangolin.interface as pi





data = bmb.load_data("sleepstudy")

data.head()





model = bmb.Model('Reaction ~ 1 + Days + (1 + Days | Subject)', data)

model


results = model.fit(draws=1000)

az.summary(results)


az.plot_trace(results)





α = pi.normal(100, 100)
β = pi.normal(0, 10)
σ = pi.exp(0.01)
μ = pi.vmap(lambda x: α + β * x)(data.Days)
Reaction = pi.vmap(lambda mu: pi.normal(mu, σ))(μ)


post = pg.blackjax.sample_arviz({ 'α' : α, 'β' : β, 'σ' : σ }, Reaction, data.Reaction)


az.summary(post)


az.plot_trace(post)



